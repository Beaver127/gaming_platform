                    </p>
                  </div>
                  <div class="stay-content-row-right">
                    <form class="stay-content-row-right-form">
                      <input
                        type="email"
                        required
                        class="stay-content-row-right-form__email"
                        name="email"
                        placeholder="Enter email address"
                      />
                      <button
                        class="stay-content-row-right-form__btn"
                        type="submit"
                      >
                        Continue
                      </button>
                    </form>
