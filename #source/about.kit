                      </div>
                      <div class="swiper-slide first-slider-slide">
                        <img
                          class="first-slider__img"
                          src="./img/about/1/1.png"
                          alt=""
                        />
                      </div>
                    </div>
                  </div>
                  <!-- Стрелки Слайдера -->
                  <div class="about-banner-row-right-arrows">
                    <div class="about-banner-row-right-arrows__left">
                      <img src="./img/about/1/arrow-left.png" alt="" />
                    </div>
                    <p class="about-banner-row-right-arrows__text"></p>
                    <div class="about-banner-row-right-arrows__right">
                      <img src="./img/about/1/arrow-right.png" alt="" />
                    </div>
