<!DOCTYPE html>
<html lang="ru">
  <head>
    <title>Gaming Platform</title>
    <meta http-equiv="Content-type" content="text/html;charset=UTF-8" />
    <meta name="format-detection" content="telephone=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/x-icon" href="./img/favicon.ico" />

    <meta name="title" content="Gaming Platform" />
    <meta property="og:title" content="Gaming Platform" />
    <meta property="twitter:title" content="Gaming Platform" />

    <meta name="description" content="Work that we produce for our clients" />
    <meta property="og:description" content="Work that we produce for our clients" />
    <meta property="twitter:description" content="Work that we produce for our clients" />

    <meta property="og:image" content="./img/preview.png" />
    <meta property="twitter:image" content="./img/preview.png" />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />

    <link rel="stylesheet" href="css/style.css" />
    <link rel="stylesheet" href="css/custom.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />
  </head>
  <body>
    <div class="wrapper">
      <div class="content">
        <!-- @import "header.html" -->
        <div class="banner">
          <div class="banner-body">
            <div class="container">
              <div class="banner-wrapper">
                <p class="banner__overtitle">3D game Dev</p>
                <h1 class="banner__title">
                  Work that we produce for our clients
                </h1>
                <p class="banner__subtitle">
                  Lorem Ipsum is simply dummy text of the printing and
                  typesetting industry. Lorem Ipsum has been the industry's
                  standard.
                </p>
                <div class="banner__btn-wrapper">
                  <div class="banner__btn btn-hover">Get more details</div>
                </div>
                <div class="banner__small-img1"></div>
                <div class="banner__small-img2"></div>
                <div class="banner__small-img3"></div>
              </div>
            </div>
          </div>
        </div>
        <div class="banner-img-wrapper">
          <div class="banner-img"></div>
        </div>
        <div class="trend">
          <div class="trend__body">
            <div class="container">
              <div class="trend-top">
                <h2 class="trend-top__title">Currently Trending Games</h2>
                <p class="trend-top__btn">SEE ALL</p>
              </div>
              <div class="trend-row">
                <div class="trend-row-item">
                  <div class="trend-row-item__img">
                    <img src="./img/main/2/1.png" alt="" />
                  </div>
                  <div class="trend-row-item-bottom">
                    <img
                      class="trend-row-item-bottom__img"
                      src="./img/main/2/5.png"
                      alt=""
                    />
                    <p class="trend-row-item-bottom__text">40 Followers</p>
                  </div>
                </div>
                <div class="trend-row-item">
                  <div class="trend-row-item__img">
                    <img src="./img/main/2/2.png" alt="" />
                  </div>
                  <div class="trend-row-item-bottom">
                    <img
                      class="trend-row-item-bottom__img"
                      src="./img/main/2/5.png"
                      alt=""
                    />
                    <p class="trend-row-item-bottom__text">40 Followers</p>
                  </div>
                </div>
                <div class="trend-row-item">
                  <div class="trend-row-item__img">
                    <img src="./img/main/2/3.png" alt="" />
                  </div>
                  <div class="trend-row-item-bottom">
                    <img
                      class="trend-row-item-bottom__img"
                      src="./img/main/2/5.png"
                      alt=""
                    />
                    <p class="trend-row-item-bottom__text">40 Followers</p>
                  </div>
                </div>
                <div class="trend-row-item">
                  <div class="trend-row-item__img">
                    <img src="./img/main/2/4.png" alt="" />
                  </div>
                  <div class="trend-row-item-bottom">
                    <img
                      class="trend-row-item-bottom__img"
                      src="./img/main/2/5.png"
                      alt=""
                    />
                    <p class="trend-row-item-bottom__text">40 Followers</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="spider">
          <div class="spider__body">
            <div class="container">
              <h3 class="spider__title">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry.
              </h3>
              <div class="spider-sub">
                <p class="spider-sub__title">Lorem Ipsum</p>
                <p class="spider-sub__subtitle">
                  Lorem Ipsum is simply dummy text of the printing and
                  typesetting industry. Lorem Ipsum has been the industry's
                  standard dummy text ever since the 1500s,
                </p>
              </div>
              <div class="spider-img-wrapper">
                <img class="spider-img" src="./img/main/3/1.png" alt="" />
                <img class="spider__sub-img" src="./img/main/3/2.png" alt="" />
              </div>
            </div>
          </div>
        </div>
        <div class="ps4">
          <div class="ps4__body">
            <div class="container">
              <h4 class="ps4__title">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry.
              </h4>
              <p class="ps4__subtitle">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry. Lorem Ipsum has been the industry's standard dummy
                text ever since the 1500s,
              </p>
              <div class="ps4-row">
                <div class="ps4-row-item">
                  <div class="ps4-row-item__img">
                    <img src="./img/main/4/icon1.png" alt="" />
                  </div>
                  <p class="ps4-row-item__text">Mobile Game Development</p>
                  <img src="./img/main/4/arrow.png" alt="" />
                </div>
                <div class="ps4-row-item">
                  <div class="ps4-row-item__img">
                    <img src="./img/main/4/icon2.png" alt="" />
                  </div>
                  <p class="ps4-row-item__text">PC Game Development</p>
                  <img src="./img/main/4/arrow.png" alt="" />
                </div>
                <div class="ps4-row-item">
                  <div class="ps4-row-item__img">
                    <img src="./img/main/4/icon3.png" alt="" />
                  </div>
                  <p class="ps4-row-item__text">PS4 Game Development</p>
                  <img src="./img/main/4/arrow.png" alt="" />
                </div>
                <div class="ps4-row-item">
                  <div class="ps4-row-item__img">
                    <img src="./img/main/4/icon4.png" alt="" />
                  </div>
                  <p class="ps4-row-item__text">AR/VR Solutions</p>
                  <img src="./img/main/4/arrow.png" alt="" />
                </div>
                <div class="ps4-row-item">
                  <div class="ps4-row-item__img">
                    <img src="./img/main/4/icon5.png" alt="" />
                  </div>
                  <p class="ps4-row-item__text">AR/ VR design</p>
                  <img src="./img/main/4/arrow.png" alt="" />
                </div>
                <div class="ps4-row-item">
                  <div class="ps4-row-item__img">
                    <img src="./img/main/4/icon6.png" alt="" />
                  </div>
                  <p class="ps4-row-item__text">3D Modelings</p>
                  <img src="./img/main/4/arrow.png" alt="" />
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="our">
          <div class="our__body">
            <div class="container">
              <h5 class="our__title">Our Recent Projects</h5>
              <p class="our__subtitle">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry.
              </p>
              <div class="our-row">
                <div class="our-row__item">
                  <img src="./img/main/5/1.png" alt="" />
                </div>
                <div class="our-row__item">
                  <img src="./img/main/5/2.png" alt="" />
                </div>
                <div class="our-row__item">
                  <img src="./img/main/5/3.png" alt="" />
                </div>
                <div class="our-row__item">
                  <img src="./img/main/5/4.png" alt="" />
                </div>
                <div class="our-row__item">
                  <img src="./img/main/5/5.png" alt="" />
                </div>
                <div class="our-row__item">
                  <img src="./img/main/5/6.png" alt="" />
                </div>
              </div>
              <div class="our-btn-wrapper">
                <p class="our__btn">SEE ALL</p>
              </div>
            </div>
          </div>
        </div>
        <div class="stay">
          <div class="stay__body">
            <div class="container">
              <h6 class="stay__title">Lorem Ipsum</h6>
              <p class="stay__subtitle">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry.
              </p>
              <div class="stay-content">
                <div class="stay-content-row">
                  <div class="stay-content-row-left">
                    <p class="stay-content-row-left__title">Stay in the loop</p>
                    <p class="stay-content-row-left__subtitle">
                      Subscribe to receive the latest news and updates about
                      TDA. We promise not to spam you!
                    </p>
                  </div>
                  <div class="stay-content-row-right">
                    <form class="stay-content-row-right-form">
                      <input
                        type="email"
                        required
                        class="stay-content-row-right-form__email"
                        name="email"
                        placeholder="Enter email address"
                      />
                      <button
                        class="stay-content-row-right-form__btn"
                        type="submit"
                      >
                        Continue
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <!-- @import "footer.html" -->
      </div>
    </div>
    <!-- @import "js.html" -->
  </body>
</html>
