<!DOCTYPE html>
<html lang="ru">
  <head>
    <title>Gaming Platform - Contact Us</title>
    <meta http-equiv="Content-type" content="text/html;charset=UTF-8" />
    <meta name="format-detection" content="telephone=no" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/x-icon" href="./img/favicon.ico" />

    <meta name="title" content="Gaming Platform - Contact Us" />
    <meta property="og:title" content="Gaming Platform - Contact Us" />
    <meta property="twitter:title" content="Gaming Platform - Contact Us" />

    <meta
      name="description"
      content="Lorem Ipsum is simply dummy text of the printing and.
"
    />
    <meta
      property="og:description"
      content="Lorem Ipsum is simply dummy text of the printing and.
"
    />
    <meta
      property="twitter:description"
      content="Lorem Ipsum is simply dummy text of the printing and.
"
    />

    <meta property="og:image" content="./img/preview-contact.png" />
    <meta property="twitter:image" content="./img/preview-contact.png" />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />

    <link rel="stylesheet" href="css/style.css" />
    <link rel="stylesheet" href="css/custom.css" />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"
    />
  </head>
  <body>
    <div class="wrapper">
      <div class="content">
        <!-- @import "header.html" -->
        <div class="portfolio-banner">
          <div class="portfolio-banner-body">
            <div class="container">
              <div class="portfolio-banner-wrap">
                <div class="portfolio-banner-wrap__decor"></div>
                <div class="portfolio-banner-top">
                  <a href="/" class="portfolio-banner-top__link"> Home </a>
                  <span> > </span>
                  <span>Contact us</span>
                </div>
                <h1 class="portfolio-banner__title">
                  Lorem Ipsum is simply dummy text of the printing and.
                </h1>
              </div>
              <p class="portfolio-banner__subtitle">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry.
              </p>
              <div class="contact__img">
                <img src="./img/contact/1/1.png" alt="" />
              </div>
            </div>
          </div>
        </div>
        <div class="contact-follow">
          <div class="contact-follow__body">
            <div class="container">
              <div class="contact-follow-row">
                <div class="contact-follow-row-left">
                  <p class="contact-follow-row-left__title">Follow us</p>
                  <div class="contact-follow-row-left-socials">
                    <a href="#" class="contact-follow-row-left-socials__item">
                      <img src="./img/contact/2/1.png" alt="" />
                    </a>
                    <a href="#" class="contact-follow-row-left-socials__item">
                      <img src="./img/contact/2/2.png" alt="" />
                    </a>
                    <a href="#" class="contact-follow-row-left-socials__item">
                      <img src="./img/contact/2/3.png" alt="" />
                    </a>
                    <a href="#" class="contact-follow-row-left-socials__item">
                      <img src="./img/contact/2/4.png" alt="" />
                    </a>
                  </div>
                </div>
                <div class="contact-follow-row__decor"></div>
                <div class="contact-follow-row-center">
                  <a
                    href="tel:+94444455556"
                    class="contact-follow-row-center__phone"
                  >
                    <img src="./img/contact/2/5.png" alt="" />
                    <span>+94 4444 5555 6</span>
                  </a>
                </div>
                <div class="contact-follow-row__decor"></div>
                <div class="contact-follow-row-right">
                  <div class="contact-follow-row-right__location">
                    <img src="./img/contact/2/6.png" alt="" />
                    <span> but also the leap into electronic typesetting </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="contact-hello">
          <div class="contact-hello__body">
            <div class="container">
              <h2 class="contact-hello__title">Say hello</h2>
              <p class="contact-hello__subtitle">
                Lorem Ipsum is simply dummy text of the printing .
              </p>
              <form class="contact-hello__form">
                <div class="contact-hello-top">
                  <div class="contact-hello-top-left">
                    <p class="contact-hello-top-left__overinput">First Name</p>
                    <input
                      name="fname"
                      type="text"
                      class="contact-hello-top-left__input"
                      required
                    />
                  </div>
                  <div class="contact-hello-top-right">
                    <p class="contact-hello-top-right__overinput">Last Name</p>
                    <input
                      name="lname"
                      type="text"
                      class="contact-hello-top-right__input"
                      required
                    />
                  </div>
                </div>
                <div class="contact-hello-email">
                  <p class="contact-hello-email__overinput">Email Address</p>
                  <input
                    name="email"
                    type="email"
                    class="contact-hello-email__input"
                    required
                  />
                </div>
                <div class="contact-hello-message">
                  <p class="contact-hello-message__overinput">Message</p>
                  <textarea
                    name="message"
                    required
                    class="contact-hello-message__message"
                  ></textarea>
                </div>
                <div class="contact-hello-submit">
                  <button
                    type="submit"
                    class="contact-hello-submit__btn btn-hover"
                  >
                    Get in touch
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>
        <div class="stay">
          <div class="stay__body">
            <div class="container">
              <p class="stay__title">Lorem Ipsum</p>
              <p class="stay__subtitle">
                Lorem Ipsum is simply dummy text of the printing and typesetting
                industry.
              </p>
              <div class="stay-content">
                <div class="stay-content-row">
                  <div class="stay-content-row-left">
                    <p class="stay-content-row-left__title">Stay in the loop</p>
                    <p class="stay-content-row-left__subtitle">
                      Subscribe to receive the latest news and updates about
                      TDA. We promise not to spam you!
                    </p>
                  </div>
                  <div class="stay-content-row-right">
                    <form class="stay-content-row-right-form">
                      <input
                        type="email"
                        required
                        class="stay-content-row-right-form__email"
                        name="email"
                        placeholder="Enter email address"
                      />
                      <button
                        class="stay-content-row-right-form__btn"
                        type="submit"
                      >
                        Continue
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- @import "footer.html" -->
      </div>
    </div>
    <!-- @import "js.html" -->
  </body>
</html>
