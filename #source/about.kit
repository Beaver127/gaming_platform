                    <img src="./img/about/1/arrow-btn.png" alt="" />
                  </div>
                </div>
                <div class="about-banner-row-right">
                  <!-- Слайдер -->
                  <div class="swiper first-slider">
                    <div class="swiper-wrapper first-slider__wrap">
                      <!-- Слайды -->
                      <div class="swiper-slide first-slider-slide">
                        <img
                          class="first-slider__img"
                          src="./img/about/1/1.png"
                          alt=""
                        />
                      </div>
                      <div class="swiper-slide first-slider-slide">
                        <img
                          class="first-slider__img"
                          src="./img/about/1/1.png"
